# Copiá este archivo a ".env" en la raíz del repo y reemplazá cada valor entre <<< >>>.
# No subas .env a git (.env está en .gitignore).

# --- Next.js (Vercel / local) — login + app ---
NEXT_PUBLIC_SUPABASE_URL=<<<https://TU_REF.supabase.co>>>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<<<PEGÁ_ANON_PUBLIC_KEY_DESDE_SUPABASE_SETTINGS_API>>>
NEXT_PUBLIC_PAIS=Argentina

# --- Next.js servidor (opcional hoy; útil si movés lógica al servidor con service role) ---
SUPABASE_SERVICE_ROLE_KEY=<<<PEGÁ_SERVICE_ROLE_DESDE_SUPABASE_SETTINGS_API>>>

# --- n8n script swap-sf-http-to-supabase-native.mjs (opcional) ---
# Si tu n8n no permite GET /api/v1/credentials (405), creá la credencial "Supabase API" en la UI y pegá su id:
# INDOVINA_SUPABASE_CREDENTIAL_ID=<<<uuid_de_la_credencial>>>

# --- Google Sheets (mirror humano para Francisco) + Google Drive (fotos facturas) ---
GOOGLE_SHEET_ID=<<<ID_ENTRE_/d/_y_/edit_EN_LA_URL_DE_LA_PLANILLA>>>
GOOGLE_SERVICE_ACCOUNT_EMAIL=<<<tu-cuenta-servicio@proyecto.iam.gserviceaccount.com>>>
# Una sola línea: reemplazá saltos de línea del JSON por \n
GOOGLE_PRIVATE_KEY=<<<-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n>>>
# ID de la carpeta de Drive donde se suben las fotos de facturas.
# La carpeta tiene que estar compartida con GOOGLE_SERVICE_ACCOUNT_EMAIL como Editor.
GOOGLE_DRIVE_FOLDER_ID=<<<ID_DE_LA_CARPETA_DE_DRIVE>>>

# --- OpenAI (ruta API factura por imagen en Next, si la usás) ---
OPENAI_API_KEY=<<<sk-...>>>

# --- n8n API (scripts en /n8n desde tu PC; Cursor MCP) ---
N8N_API_URL=<<<https://tu-n8n.easypanel.host>>>
N8N_API_KEY=<<<PEGÁ_API_KEY_DESDE_N8N_SETTINGS_API>>>

# --- Mismo contenido en Easypanel → servicio n8n → Environment (si los nodos usan $env) ---
SUPABASE_URL=<<<https://TU_REF.supabase.co>>>
WEBHOOK_URL=<<<https://tu-n8n.easypanel.host/>>
N8N_HOST=<<<https://tu-n8n.easypanel.host>>>
N8N_PROTOCOL=https
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true

# --- Opcional: solo si algún nodo usa $env.TELEGRAM_BOT_TOKEN (si no, dejalo vacío o borrá la línea) ---
TELEGRAM_BOT_TOKEN=<<<TOKEN_DE_BOTFATHER_SI_LO_USÁS_POR_ENV>>>
